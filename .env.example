# Docker Hub credentials
DOCKER_USERNAME=your_docker_username

# HuggingFace token (required for gated models like Qwen3-8B)
# Generate at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights & Biases API key (optional — training works without it, but metrics won't be logged)
# Generate at https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vast.ai API key (read from ~/.vast_api_key by default)
# Generate at https://cloud.vast.ai/account/cli
# VAST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Training configuration (optional — defaults shown)
# TRAINING_STEPS=20
# GAMES_PER_STEP=18
